<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- ─────────────────────────────────────────────────────────────────
     We'll Share — TestNG Suite  (3 core test flows)
     Run all:    mvn test
     Run smoke:  mvn test -Dgroups=smoke
     ───────────────────────────────────────────────────────────────── -->
<suite name="WellShare-AutomationSuite" parallel="false" verbose="2">

    <!-- ══ SMOKE — quick sanity check before full regression ════════ -->
    <test name="Smoke-Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.wellshare.tests.LoginTest"/>
            <class name="com.wellshare.tests.NavigationTest"/>
        </classes>
    </test>

    <!-- ══ REGRESSION — full coverage of 3 core flows ═════════════ -->
    <test name="Regression-Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <!-- Flow 1: Login scenarios (5 test cases) -->
            <class name="com.wellshare.tests.LoginTest"/>

            <!-- Flow 2: Ride Search scenarios (5 test cases) -->
            <class name="com.wellshare.tests.RideSearchTest"/>

            <!-- Flow 3: Navigation / page routing (6 test cases) -->
            <class name="com.wellshare.tests.NavigationTest"/>
        </classes>
    </test>

</suite>
