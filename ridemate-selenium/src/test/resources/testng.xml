<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- ─────────────────────────────────────────────────────────────────
     We'll Share — TestNG Suite
     Run all:   mvn test
     Run group: mvn test -Dgroups=smoke
     ───────────────────────────────────────────────────────────────── -->
<suite name="WellShare-AutomationSuite" parallel="false" verbose="1">

    <!-- ══ SMOKE TESTS — Run these first, quick sanity check ══════ -->
    <test name="Smoke-Tests">
        <groups>
            <run><include name="smoke"/></run>
        </groups>
        <classes>
            <class name="com.wellshare.tests.LoginTest"/>
            <class name="com.wellshare.tests.NavigationTest"/>
        </classes>
    </test>

    <!-- ══ REGRESSION TESTS — Full coverage ══════════════════════ -->
    <test name="Regression-Tests">
        <groups>
            <run><include name="regression"/></run>
        </groups>
        <classes>
            <class name="com.wellshare.tests.SignupTest"/>
            <class name="com.wellshare.tests.LoginTest"/>
            <class name="com.wellshare.tests.RideSearchTest"/>
            <class name="com.wellshare.tests.BookingFlowTest"/>
            <class name="com.wellshare.tests.ParcelTest"/>
            <class name="com.wellshare.tests.ProfileTest"/>
            <class name="com.wellshare.tests.AdminTest"/>
            <class name="com.wellshare.tests.NavigationTest"/>
        </classes>
    </test>

</suite>
